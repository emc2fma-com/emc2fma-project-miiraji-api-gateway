
management.endpoints.web.exposure.include=*
management.endpoints.web.exposure.exclude=env,beans
management.endpoint.health.show-details=always
management.endpoint.prometheus.enabled=true
management.prometheus.metrics.export.enabled=true
management.observations.key-values.application=api-gateway
management.tracing.enabled=true
management.tracing.sampling.probability=1.0
management.tracing.zipkin.enabled=false
management.zipkin.enabled=false
management.zipkin.tracing.endpoint=
management.tracing.propagation.consume=w3c,b3
management.tracing.propagation.produce=w3c,b3
management.tracing.propagation.type=w3c,b3

server.port=8080
spring.main.web-application-type=reactive
spring.application.name=api-gateway

#=======================swagger====================
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.enabled=true
springdoc.api-docs.enabled=true
#=======================swagger====================

#=======================logging====================
logging.level.root=INFO
logging.level.org.springdoc=INFO
logging.level.org.springframework=INFO
logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] **[User:%X{userId}, CID:%X{correlationId}]** [%-5level] %logger{0} - %msg%n
logging.pattern.file=
logging.file.debug.path=
logging.file.info.path=
logging.file.warn.path=
logging.file.error.path=
logging.file.path=
logging.level.io.micrometer=INFO
logging.level.io.opentelemetry=INFO
logging.level.io.opentelemetry.exporter.zipkin=OFF
#=======================logging====================


#===================================security===========================

security.white.paths=
routes.apis.[/sample/v1]=http:///sample:40/

#=======================cors====================
security.cors.enable=true
security.cors.allowed.headers=*
security.cors.allowed.origins=*
security.cors.allowed.methods=*
security.cors.creds=false
security.cors.maxAge=5
#=======================cors====================

#=======================jwt====================
security.jwt.token.expiration=10
security.jwt.public.type=STRING
security.jwt.private.type=STRING
#=======================jwt====================

#=======================string_key====================
security.jwt.string.public.Key=
security.jwt.string.private.Key=
#=======================string===========


#=======================jwt_store====================
security.jwt.public.store=
security.jwt.private.store=
#=======================jwt_store====================

#=======================rsa_key====================
security.jwt.rsa.fs.storepass=
security.jwt.rsa.fs.keypass=
security.jwt.rsa.fs.alias=
#=======================rsa_key====================

#=======================user====================

user.service.api.url=
user.service.api.path.name=
user.service.api.path.id=
user.service.api.query=
user.service.api.headers=
#===================================User DB===========================
spring.datasource.url=jdbc:mysql://localhost:3306/<>
spring.datasource.username=
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

user.default.userName=admin
user.default.pwd=admin123
user.default.roleName=admin
user.default.firstName=Admin
user.default.lastName=User
user.default.startDate=2026-01-19
user.default.endDate=2028-01-19
user.default.dob=1990-01-30
#===================================User DB===========================

#=======================user====================

#=======================file_system====================
security.jwt.fs.public.path=
security.jwt.fs.private.path=
#=======================file_system====================

#=======================aws====================
security.jwt.aws.public.region=
security.jwt.aws.public.secret=
security.jwt.aws.public.access=
security.jwt.aws.public.bucket=
security.jwt.aws.public.path=

security.jwt.aws.private.region=
security.jwt.aws.private.secret=
security.jwt.aws.private.access=
security.jwt.aws.private.bucket=
security.jwt.aws.private.path=
#=======================aws====================

#=======================azure====================
security.jwt.azure.public.connectionString=
security.jwt.azure.public.containerName=
security.jwt.azure.public.blobName=

security.jwt.azure.private.connectionString=
security.jwt.azure.private.containerName=
security.jwt.azure.private.blobName=
#=======================azure====================

#=======================rate-limiter====================
security.rl.enabled=false
security.rl.burstRate=100
security.rl.windowSeconds=1
security.rl.header.key=
security.rl.redis.host=
security.rl.redis.port=
security.rl.redis.dbindex=1
security.rl.redis.uname=
security.rl.redis.pwd=
#=======================rate-limiter====================
#===================================security===========================

#===========================================circuit-breaker======================================
spring.cloud.circuitbreaker.resilience4j.enabled=false
resilience4j.circuitbreaker.instances.default.minimumNumberOfCalls=5
resilience4j.circuitbreaker.instances.default.failureRateThreshold=50
resilience4j.circuitbreaker.instances.default.slowCallRateThreshold4=
resilience4j.circuitbreaker.instances.default.slowCallDurationThreshold=
resilience4j.circuitbreaker.instances.default.permittedNumberOfCallsInHalfOpenState=3
resilience4j.circuitbreaker.instances.default.maxWaitDurationInHalfOpenState=
resilience4j.circuitbreaker.instances.default.slidingWindowType=COUNT_BASED
resilience4j.circuitbreaker.instances.default.slidingWindowSize=10
resilience4j.circuitbreaker.instances.default.waitDurationInOpenState=10000
resilience4j.circuitbreaker.instances.default.automaticTransitionFromOpenToHalfOpenEnabled=true
#===========================================circuit-breaker======================================
